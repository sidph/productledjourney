---
import { SITE_TITLE } from '../consts';
---

<section class="blog-intro">
	<h1>{SITE_TITLE}</h1>
	<hr class="accent-rule" />
	<p class="tagline">Product-led growth, from the trenches</p>
</section>

<style>
	.blog-intro {
		margin-bottom: 3rem;
	}

	h1 {
		margin: 0 0 0.75rem;
		font-size: 2.5rem;
		line-height: 1.2;
	}

	.accent-rule {
		width: 3rem;
		height: 3px;
		margin: 0 0 1rem;
		border: none;
		background: #c7831d;
	}

	.tagline {
		margin: 0;
		font-size: 1.15rem;
		line-height: 1.5;
		color: #c7831d;
		font-style: italic;
	}

	@media (max-width: 700px) {
		h1 {
			font-size: 2rem;
		}

		.tagline {
			font-size: 1.05rem;
		}
	}
</style>
